output$export <- downloadHandler(
filename = function() {
"menstrual_history.html"
},
content = function(file) {
data <- history()
text <- c("# First day", "")
if (nrow(data) == 0) {
text <- c(text, "No periods registered.")
} else {
for (i in 1:nrow(data)) {
